generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CEO
  MANAGER
  EMPLOYEE
  CLIENT
}

enum Level {
  BRONZE
  SILVER
  GOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  PENDING_APPROVAL
  DONE
  LATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TaskRepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum ProjectStatus {
  IN_PROGRESS
  AT_RISK
  COMPLETED
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  email          String           @unique
  password       String
  role           Role
  createdAt      DateTime         @default(now())
  sectionId      Int?
  section        Section?         @relation("SectionMembers", fields: [sectionId], references: [id])
  managedSection Section?         @relation("SectionManager")
  createdTasks   Task[]           @relation("TaskCreator")
  assignedTasks  Task[]           @relation("TaskAssignee")
  managedProjects Project[]       @relation("ProjectManager")
  clientProjects  Project[]       @relation("ProjectClient")
  projectComments ProjectComment[]
  scores         Score[]
  stars          Int              @default(0)
  level          Level            @default(BRONZE)
  onTimeCount    Int              @default(0)
  notifications  Notification[]
}

model Section {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  managerId Int?      @unique
  manager   User?     @relation("SectionManager", fields: [managerId], references: [id])
  members   User[]    @relation("SectionMembers")
  tasks     Task[]
  projects  Project[]
}

model Project {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  status      ProjectStatus @default(IN_PROGRESS)
  budget      String?
  deadline    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  clientId    Int
  client      User          @relation("ProjectClient", fields: [clientId], references: [id])
  managerId   Int
  manager     User          @relation("ProjectManager", fields: [managerId], references: [id])
  sectionId   Int
  section     Section       @relation(fields: [sectionId], references: [id])
  tasks       Task[]
  comments    ProjectComment[]
}

model Task {
  id                 Int            @id @default(autoincrement())
  title              String
  description        String?
  prCompanyName      String?
  prGovernmentEntity String?
  prTransactionType  String?
  prGovernmentEmployee String?
  prApplicationNumber String?
  prTaxIdNumber      String?
  prNationalIdNumber String?
  prNotes            String?
  prUpdates          String?
  status             TaskStatus     @default(TODO)
  priority           String         @default("medium")
  deadline           DateTime
  repeatType         TaskRepeatType @default(NONE)
  repeatEvery        Int            @default(1)
  repeatUntil        DateTime?
  recurrenceGroupId  String?
  recurrenceIndex    Int            @default(0)
  createdAt          DateTime       @default(now())
  completedAt        DateTime?
  creatorId          Int
  creator            User           @relation("TaskCreator", fields: [creatorId], references: [id])
  assigneeId         Int
  assignee           User           @relation("TaskAssignee", fields: [assigneeId], references: [id])
  sectionId          Int
  section            Section        @relation(fields: [sectionId], references: [id])
  projectId          Int?
  project            Project?       @relation(fields: [projectId], references: [id])
  parentId           Int?
  parent             Task?          @relation("SubTasks", fields: [parentId], references: [id])
  subtasks           Task[]         @relation("SubTasks")
  score              Score?
  evidenceUrl        String?
  evidenceUrls       String[]       @default([])
  evidenceNote       String?
  evidenceUploadedAt DateTime?
  approvalStatus     ApprovalStatus @default(PENDING)
  approvalComment    String?
  approvalBy         Int?
  approvalAt         DateTime?

  @@index([recurrenceGroupId])
}

model Score {
  id        Int      @id @default(autoincrement())
  value     Int
  isOnTime  Boolean
  createdAt DateTime @default(now())
  adjusted  Boolean  @default(false)
  adjustedBy Int?
  taskId    Int      @unique
  task      Task     @relation(fields: [taskId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String
  message   String
  read      Boolean  @default(false)
  taskId    Int?
  createdAt DateTime @default(now())
}

model ProjectComment {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}
